      "tesis": "[[{autores} ]]({año}). <i>{titulo}</i> [{clase}[[, {institucion}]]].[[ {url}]]",
      "informe": "[[{autores} ]]({año}). <i>{titulo}</i>.[[ {institucion}.]][[ {url}]]"
    }
  },

